# Copy this file to .env and set your keys.
# The script scripts/split_user_location.py auto-loads .env.

# ------------------------------------------------------------
# Generic single-provider variables (used by split_user_location.py)
# ------------------------------------------------------------
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemma-2-9b-it:free

# ------------------------------------------------------------
# Multi-provider comparison variables
# Used by scripts/run_provider_comparison.py
# ------------------------------------------------------------

# Input/output controls
INPUT_CSV=processed_tourism_reviews.csv
OUTPUT_A_CSV=processed_tourism_reviews_country_other_openrouter.csv
OUTPUT_B_CSV=processed_tourism_reviews_country_other_groq.csv
MISMATCHES_OUT=location_llm_mismatches.csv

# Provider A: OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Provider B: Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
